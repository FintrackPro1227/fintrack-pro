# FinTrack Pro — Environment Variables
# Copy file ini menjadi .env dan isi nilainya

# ── DATABASE ──
# Akan diisi otomatis oleh Railway
DATABASE_URL="postgresql://user:password@host:5432/fintrack"

# ── SERVER ──
PORT=3000
NODE_ENV=production

# ── SECURITY ──
# Ganti dengan string acak yang panjang (minimal 32 karakter)
JWT_SECRET="ganti-dengan-string-rahasia-yang-sangat-panjang-dan-acak-2026"
SESSION_SECRET="ganti-dengan-string-session-yang-berbeda-dan-acak-2026"

# ── AI (Claude API) ──
# Dapatkan dari: https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-xxxx"

# ── ADMIN ACCOUNT ──
ADMIN_EMAIL="admin@fintrackpro.id"
ADMIN_PASSWORD="FinTrack2026!"

# ── OPTIONAL: Email notifications ──
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="email@gmail.com"
# SMTP_PASS="app-password"
